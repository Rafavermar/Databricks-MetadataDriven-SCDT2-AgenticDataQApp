T*
() Tj
T*
(    1\) Load env) Tj
T*
(       . .\\.load-env.ps1) Tj
T*
() Tj
T*
(    2\) Validate and deploy) Tj
T*
(       databricks bundle validate -t dev) Tj
T*
(       $env:BUNDLE_VAR_dq_fail_on_issues="false") Tj
T*
(       databricks bundle deploy -t dev) Tj
T*
() Tj
T*
(    3\) Seed data) Tj
T*
(       python scripts/00_mongo_simulator.py --mode reset_and_seed) Tj
T*
() Tj
T*
(    4\) Run job) Tj
T*
(       databricks bundle run -t dev poc_pipeline_job) Tj
T*
() Tj
T*
(    5\) Start app) Tj
T*
(       databricks bundle run -t dev dq_rescue_agent) Tj
T*
() Tj
